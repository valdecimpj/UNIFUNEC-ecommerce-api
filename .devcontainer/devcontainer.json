// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/java-postgres
{
	"name": "Java & Various Services",
	"dockerComposeFile": "docker-compose.yml",
	"service": "app",
	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

	// Forward all infrastructure service ports to the host machine
	"forwardPorts": [
		5432,   // PostgreSQL
		27017,  // MongoDB
		9092,   // Kafka
		5672,   // RabbitMQ AMQP
		15672,  // RabbitMQ Management UI
		8761,   // Eureka Server
		6379,   // Redis
		9411,   // Zipkin
		9090,   // Prometheus
		3000,   // Grafana
		9080,   // Kafka UI
		5540,   // RedisInsight
		8082,   // mongo-express
		8978    // CloudBeaver
	],

	"portsAttributes": {
		"5432":  { "label": "PostgreSQL" },
		"27017": { "label": "MongoDB" },
		"9092":  { "label": "Kafka" },
		"5672":  { "label": "RabbitMQ" },
		"15672": { "label": "RabbitMQ Management" },
		"8761":  { "label": "Eureka Server" },
		"6379":  { "label": "Redis" },
		"9411":  { "label": "Zipkin" },
		"9090":  { "label": "Prometheus" },
		"3000":  { "label": "Grafana" },
		"9080":  { "label": "Kafka UI" },
		"5540":  { "label": "RedisInsight" },
		"8082":  { "label": "mongo-express" },
		"8978":  { "label": "CloudBeaver" }
	},

	// Features to add to the dev container. More info: https://containers.dev/features.
	"features": {
    	"ghcr.io/devcontainers/features/docker-in-docker:3": {}
	}

	// Use 'postCreateCommand' to run commands after the container is created.
	// "postCreateCommand": "java -version",

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
